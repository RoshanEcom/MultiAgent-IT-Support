# --- OpenAI (required) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Jira integration (optional) ---
# If left blank, the Jira MCP tool falls back to a mock that prints to console
# and returns a fake ticket ID. The system runs end-to-end without these.
# To use real Jira:
#   1. Create a free workspace at https://www.atlassian.com/software/jira/free
#   2. Generate an API token at https://id.atlassian.com/manage-profile/security/api-tokens
#   3. Fill the four variables below.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=IT

# --- Local paths ---
KB_DIR=knowledge_base
CHROMA_DIR=.chroma
